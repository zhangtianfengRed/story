  npcLines:
  - "\u4F60\u5E73\u65F6\u8BDD\u662F\u4E0D\u662F\u4E0D\u591A\uFF1F\u611F\u89C9\u4F60\u5F88\u5B89\u9759\u3002"
  choices:
  - choiceText: "\u5BF9\u2026\u6211\u4F1A\u6015\u8BF4\u9519\u8BDD\uFF0C\u6240\u4EE5\u5E72\u8106\u5148\u5C11\u8BF4"
    worryThoughts:
    - "\u627F\u8BA4\u8BDD\u5C11\u4F1A\u4E0D\u4F1A\u6263\u5206\uFF1F"
    - "\u4F46\u8FD9\u662F\u6211"
    - "\u6211\u4E0D\u60F3\u88C5\u6210\u5F88\u4F1A\u804A"
    - "\u5979\u8981\u662F\u89C9\u5F97\u65E0\u804A\u5C31\u5B8C\u4E86"
    - "\u8FD9\u6837\u8BF4\u5BF9\u5417\uFF1F"
    nextDialogue: {fileID: 11400000, guid: 50c1caeb3be232745967a4b531cdff4c, type: 2}
  - choiceText: "\u6CA1\u6709\uFF0C\u6211\u5176\u5B9E\u5F88\u4F1A\u804A\u7684\uFF0C\u5C31\u662F\u521A\u89C1\u9762\u6211\u4F1A\u5148\u793C\u8C8C\u4E00\u70B9"
    worryThoughts:
    - "\u522B\u8BF4\u592A\u6EE1"
    - "\u51C6\u5907\u4E00\u4E2A\u8BDD\u9898\uFF0C\u5FEB"
    - "\u522B\u88AB\u5979\u8BD5\u51FA\u6765"
    - "\u5979\u9A6C\u4E0A\u4F1A\u95EE\uFF1A\u90A3\u4F60\u804A\u70B9\u5565"
    - "\u8FD9\u6837\u8BF4\u5BF9\u5417\uFF1F"
