  m_Name: Talk2
  m_EditorClassIdentifier: 
  npcLines:
  - "\u522B\u7D27\u5F20\uFF0C\u6211\u4EEC\u968F\u4FBF\u804A\u804A\u5C31\u597D"
  - "\u4F60\u4ECA\u5929\u8FC7\u6765\u8DEF\u4E0A\u987A\u5229\u5417\uFF1F"
  choices:
  - choiceText: "\u987A\u5229\u987A\u5229\u2026\u6211\u4E5F\u521A\u5230\u6CA1\u591A\u4E45\u3002\u4F60\u8DEF\u4E0A\u8FD8\u597D\u5417\uFF1F"
    worryThoughts:
    - "\u5148\u56DE\u7B54\u2018\u987A\u5229\u2019\uFF0C\u8FD9\u662F\u6807\u51C6\u7B54\u6848\u3002"
    - "\u522B\u8BF4\u592A\u591A"
    - "\u95EE\u56DE\u53BB\u6700\u5B89\u5168\uFF0C\u4E0D\u4F1A\u51B7\u573A"
    - "\u6211\u8BF4\u2018\u987A\u5229\u987A\u5229\u2019\u4F1A\u4E0D\u4F1A\u592A\u50CF\u5E94\u4ED8\uFF1F"
    - "\u58F0\u97F3\u522B\u6296\u2026\u522B\u6296\u2026"
    nextDialogue: {fileID: 11400000, guid: 9aeb77fe3ec937042841d242ef4d0471, type: 2}
  - choiceText: "\u8FD8\u884C\u2026\u6211\u521A\u521A\u5DEE\u70B9\u8D70\u9519\u8DEF\uFF0C\u6015\u81EA\u5DF1\u8FDF\u5230\u5C31\u4E00\u8DEF\u76EF\u7740\u5BFC\u822A\uFF08\u7B11\uFF09\u3002\u4F60\u8FD8\u987A\u5229\u5417\uFF1F"
    worryThoughts:
    - "\u8BA4\u5DEE\u70B9\u8D70\u9519\u4F1A\u4E0D\u4F1A\u663E\u5F97\u6211\u5F88\u7B28\uFF1F"
    - "\u4F46\u8BF4\u70B9\u5C0F\u5931\u8BEF\uFF0C\u53CD\u800C\u50CF\u4EBA"
    - "\u522B\u7B11\u592A\u5047\uFF0C\u522B\u7B11\u592A\u5047"
    - "\u8BB2\u592A\u591A\u7EC6\u8282\u5979\u4F1A\u4E0D\u4F1A\u70E6\uFF1F"
    - "\u6211\u662F\u4E0D\u662F\u53C8\u5728\u7528\u2018\u7B11\u2019\u63A9\u9970\u7D27\u5F20\uFF1F"
    nextDialogue: {fileID: 11400000, guid: 9aeb77fe3ec937042841d242ef4d0471, type: 2}
  isEndingScene: 0
